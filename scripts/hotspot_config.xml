<config>
    <!-- Basic Wi-Fi Settings -->
    <ssid> drors_rpi </ssid> <!-- Network name -->
    <password> 21091965 </password> <!-- Network password (minimum 8 characters) -->
    
    <!-- Advanced Wi-Fi Settings -->
    <band> 2.4 </band> <!-- WIFI operation band - 2.4 or 5 (range vs rates) -->
    
    <!-- For 2.4 GHz, use channels 1, 6, or 11. For 5 GHz, use 36, 40, 44, 48 -->
    <!-- Leave as "auto" to let the router choose the best channel automatically -->
    <channel> auto </channel>

    <!-- Network Configuration -->
    <auto_connect> yes </auto_connect> <!-- Auto activate the router when connected to power -->

    <!-- Source selection -->
    <source> ethernet </source> <!-- ethernet or wifi doungle -->

    <!-- Upstream settings (only required if source is wifi) -->
    <upstream_ssid> home_wifi_name </upstream_ssid>
    <upstream_password> home_wifi_password </upstream_password>

</config>